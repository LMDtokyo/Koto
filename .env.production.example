# ─── Koto Production Environment ─────────────────────────────────────────────
# СКОПИРУЙТЕ В .env.production И ЗАПОЛНИТЕ. НЕ КОММИТЬТЕ.
# Стартовать: docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#             --env-file .env.production up -d --build

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=koto
# openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_ME_LONG_RANDOM

# ─── Dragonfly (Redis-compatible) ─────────────────────────────────────────────
# openssl rand -base64 32
DRAGONFLY_PASSWORD=REPLACE_ME_LONG_RANDOM

# ─── MinIO ────────────────────────────────────────────────────────────────────
# openssl rand -hex 16
MINIO_ACCESS_KEY=REPLACE_ME
# openssl rand -base64 32
MINIO_SECRET_KEY=REPLACE_ME_LONG_RANDOM
# Публичный hostname для presigned URL'ов. Caddy проксирует на minio:9000.
MINIO_PUBLIC_ENDPOINT=media.koto.run
MINIO_PUBLIC_USE_SSL=true

# ─── JWT Ed25519 ──────────────────────────────────────────────────────────────
# Сгенерировать новую пару ключей в проде:
#   go run infra/scripts/keygen/main.go
# Скопировать в две переменные ниже. ОБА должны быть в hex.
JWT_PRIVATE_KEY_SEED=REPLACE_ME_64_HEX_CHARS
JWT_PUBLIC_KEY=REPLACE_ME_64_HEX_CHARS

# ─── Internal Service Auth ────────────────────────────────────────────────────
# openssl rand -hex 32
INTERNAL_SECRET=REPLACE_ME_LONG_RANDOM

# ─── WebSocket CORS ───────────────────────────────────────────────────────────
# Гейтвей проверяет Origin при WebSocket-handshake.
# Tauri-приложение присылает Origin = "tauri://localhost"; добавьте оба.
ALLOWED_ORIGIN=koto.run,tauri://localhost

# ─── APNs (опционально, до выхода iOS-клиента можно оставить) ────────────────
APNS_KEY_PATH=/run/secrets/apns_key.p8
APNS_KEY_ID=ABCDE12345
APNS_TEAM_ID=TEAM123456
APNS_BUNDLE_ID=run.koto.messenger

# ─── Caddy / TLS ──────────────────────────────────────────────────────────────
# Email для Let's Encrypt account / уведомлений по сертификатам.
CADDY_ACME_EMAIL=ops@koto.run
# Owner GitHub для редиректа с koto.run/ на /releases/latest (до сайта).
KOTO_GITHUB_OWNER=your-org
